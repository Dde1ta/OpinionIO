FROM python:3.12-slim

WORKDIR /app

# Copy requirements first (for better layer caching)
COPY Apis/internal/requirements-internal.txt .

# Install dependencies
RUN pip install --no-cache-dir -r requirements-internal.txt

# Copy shared General module
COPY General/ ./General/

# Copy only the internal API
COPY Apis/__init__.py ./Apis/
COPY Apis/internal/ ./Apis/internal/

# Set Python path so imports work
ENV PYTHONPATH=/app

# Expose the internal API port
EXPOSE 8001

CMD ["uvicorn", "Apis.internal.main:internal", "--host", "0.0.0.0", "--port", "8001"]
